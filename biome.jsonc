{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "extends": ["ultracite"],
  "linter": {
    "rules": {
      "nursery": {
        "noUnknownAtRule": "off"
      }
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**/*", "!src/components/ui/*", "!src/hooks/use-toast.ts"]
  }
}
